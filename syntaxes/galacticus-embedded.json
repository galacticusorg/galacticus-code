{
  "fileTypes": [
    "F90"
  ],
  "injectionSelector": "L:source.fortran.free",
  "patterns": [
    {
      "comment": "Embedded XML directive blocks:  !![ ... !!]",
      "begin": "^\\s*!!\\[",
      "end": "^\\s*!!\\]",
      "beginCaptures": {
        "0": { "name": "comment.line.exclamation.galacticus" }
      },
      "endCaptures": {
        "0": { "name": "comment.line.exclamation.galacticus" }
      },
      "contentName": "meta.embedded.block.xml",
      "patterns": [
        { "include": "text.xml" }
      ]
    },
    {
      "comment": "Embedded reStructuredText docstrings:  !!{RST ... !!}  (formerly LaTeX)",
      "begin": "^\\s*!!\\{(?:RST\\b)?",
      "end": "^\\s*!!\\}",
      "beginCaptures": {
        "0": { "name": "comment.line.exclamation.galacticus" }
      },
      "endCaptures": {
        "0": { "name": "comment.line.exclamation.galacticus" }
      },
      "contentName": "meta.embedded.block.restructuredtext",
      "patterns": [
        { "include": "source.rst" }
      ]
    }
  ],
  "scopeName": "inline.galacticus"
}
